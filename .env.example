# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://shipops:shipops@localhost:5433/shipops?schema=public"

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/port-calls
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Service Providers (demo defaults — no external keys needed) ──────────────
# Each PROVIDER_* selects the adapter for that service. Values map to the
# `case` branches in packages/services/src/<service>/registry.ts. Today only
# the listed values are wired; setting anything else throws at first access.
PROVIDER_AIS=mock
PROVIDER_EMAIL=mock
PROVIDER_OCR=mock
PROVIDER_LLM=mock
PROVIDER_SANCTIONS=mock
PROVIDER_STORAGE=local
PROVIDER_PDF=mock
# STORAGE_LOCAL_ROOT — optional override for the local-fs storage adapter's
# root directory. Defaults to <monorepo-root>/apps/web/.uploads when unset.
# STORAGE_LOCAL_ROOT=

# ─── Azure (Phase 2+ — leave blank for demo) ─────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_AI_ENDPOINT=
AZURE_AI_KEY=

# ─── Email (Phase 2+ — leave blank for demo) ─────────────────────────────────
SENDGRID_API_KEY=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=

# ─── AI (Phase 2+ — leave blank for demo) ────────────────────────────────────
ANTHROPIC_API_KEY=
